rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Données non sensibles — lecture/écriture libre (mot de passe admin côté client)
    match /quizzes/{quizId} {
      allow read, write: if true;
    }

    match /results/{resultId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /vocab_words/{vocabId} {
      allow read, write: if true;
    }

    match /comportement/{doc} {
      allow read, write: if true;
    }

    match /comportement_months/{doc} {
      allow read, write: if true;
    }

    // Settings (stocke le mot de passe admin)
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Par défaut : refuser
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}